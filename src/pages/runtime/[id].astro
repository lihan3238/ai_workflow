---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  runtimeDeviceIdentityLine,
  runtimeDeviceInventoryLine,
  runtimeDeviceStatusLine,
  runtimeGuideVerificationLine,
  type RuntimeToolSnapshot
} from "../../lib/runtime/inventory";
import { diffTextForComparison, loadRuntimeState } from "../../lib/runtime/load";

export async function getStaticPaths() {
  const runtime = await loadRuntimeState();
  return runtime.comparisons.map((comparison) => ({
    params: { id: comparison.device.id },
    props: { comparison }
  }));
}

const { comparison } = Astro.props;
const diffText = diffTextForComparison(comparison);
const diffCommand = `npm run runtime:diff -- --device runtime/devices/${comparison.device.id}.json`;
const syncCommand = `npm run runtime:sync -- --device runtime/devices/${comparison.device.id}.json --target-root <device-repo-root> --apply`;
const agentsGuide = comparison.device.agent_guides.agents_md;
const claudeGuide = comparison.device.agent_guides.claude_md;
const guideVerification = comparison.device.guide_verification;
const runtimeTools = [
  ["Claude Code", comparison.device.tools?.claude, true],
  ["Codex", comparison.device.tools?.codex, true],
  ["cc-switch", comparison.device.tools?.cc_switch, false]
] as Array<[string, RuntimeToolSnapshot | undefined, boolean]>;

function pathList(paths: string[] | undefined): string {
  return paths && paths.length > 0 ? paths.join(", ") : "未发现";
}
---

<BaseLayout title={comparison.device.label} section="runtime">
  <p class="eyebrow">Device detail</p>
  <h1 class="page-title">{comparison.device.label}</h1>
  <p class="lead">{runtimeDeviceIdentityLine(comparison.device)}。{runtimeDeviceStatusLine(comparison.device)}。</p>
  <p class="lead">{runtimeDeviceInventoryLine(comparison.device)}</p>
  {comparison.device.inventory_note && <p class="lead">{comparison.device.inventory_note}</p>}

  <section class="section">
    <div class="device-actions">
      <a class="button inline-button" href="/runtime/">返回 Devices</a>
      <button class="button danger" id="device-delete-button" type="button" data-device-id={comparison.device.id}>
        删除主机
      </button>
    </div>
  </section>

  <section class="section">
    <div class="grid cols-4">
      <div class="panel metric">
        <span>Missing</span>
        <strong>{comparison.counts.missing}</strong>
      </div>
      <div class="panel metric">
        <span>Changed</span>
        <strong>{comparison.counts.changed}</strong>
      </div>
      <div class="panel metric">
        <span>Extra</span>
        <strong>{comparison.counts.extra}</strong>
      </div>
      <div class="panel metric">
        <span>In sync</span>
        <strong>{comparison.counts.in_sync}</strong>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="guide-layout">
      <div class="panel">
        <h3>AGENTS.md canonical content</h3>
        <p>{agentsGuide.path}</p>
        {agentsGuide.resolved_path && <p>{agentsGuide.resolved_path}</p>}
        <pre class="guide-content">{agentsGuide.content || "尚未采集 AGENTS.md 全文"}</pre>
      </div>
      <div class="panel">
        <h3>CLAUDE.md verification</h3>
        <div class="asset-meta">
          <span class:list={["status-chip", guideVerification?.status === "verified" ? "online" : "offline"]}>
            {guideVerification?.status || "unknown"}
          </span>
          <span class="tag">{guideVerification?.mode || "unknown"}</span>
        </div>
        <p>{runtimeGuideVerificationLine(guideVerification)}</p>
        <ul class="compact-list">
          <li>CLAUDE.md status: {claudeGuide.status}</li>
          <li>CLAUDE.md path: {claudeGuide.path}</li>
          {claudeGuide.resolved_path && <li>resolved: {claudeGuide.resolved_path}</li>}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Toolchain</h2>
    </div>
    <div class="tool-grid">
      {runtimeTools.map(([label, tool, showsManagedState]) => (
        <div class="panel tool-panel">
          <div class="asset-meta">
            <span class:list={["tool-badge", tool?.installed ? "installed" : "missing"]}>
              {tool?.installed ? "installed" : "missing"}
            </span>
            {showsManagedState && tool?.managed_by_cc_switch && (
              <span class="tool-badge installed">cc-switch managed</span>
            )}
          </div>
          <h3>{label}</h3>
          <ul class="compact-list tool-detail-list">
            <li>version: {tool?.version || "unknown"}</li>
            <li>binary: {tool?.binary_path || "未发现"}</li>
            <li>config: {pathList(tool?.config_paths)}</li>
            {tool?.data_paths && <li>data: {pathList(tool.data_paths)}</li>}
            {tool?.db_user_version !== undefined && <li>cc-switch DB user_version: {tool.db_user_version}</li>}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="runtime-columns">
      <div class="panel">
        <h3>Skills</h3>
        <ul class="compact-list">
          {comparison.device.skills.map((skill) => (
            <li>{skill.tool}:{skill.name} - {skill.status}</li>
          ))}
        </ul>
      </div>
      <div class="panel">
        <h3>Projects</h3>
        <ul class="compact-list">
          {comparison.device.projects.length === 0 ? (
            <li>尚未采集远端项目清单</li>
          ) : (
            comparison.device.projects.map((project) => (
              <li>
                <strong>{project.name}</strong> - {project.status}
                {project.branch && ` - ${project.branch}`}
                <br />
                {project.path}
                {project.remote_url && (
                  <>
                    <br />
                    {project.remote_url}
                  </>
                )}
                {project.markers && project.markers.length > 0 && (
                  <>
                    <br />
                    markers: {project.markers.join(", ")}
                  </>
                )}
              </li>
            ))
          )}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Diff</h2>
    </div>
    <div class="diff-panel open-panel">
      <pre>{diffText || "No asset drift."}</pre>
    </div>
  </section>

  <section class="section">
    <div class="grid cols-2">
      <div class="panel">
        <h3>CLI diff</h3>
        <code class="command">{diffCommand}</code>
      </div>
      <div class="panel">
        <h3>确认后同步</h3>
        <code class="command">{syncCommand}</code>
      </div>
    </div>
  </section>

  <dialog class="confirm-dialog" id="runtime-confirm-dialog">
    <form class="confirm-card" method="dialog">
      <h3 id="runtime-confirm-title">确认操作</h3>
      <p id="runtime-confirm-message"></p>
      <div class="dialog-actions">
        <button class="button" value="cancel">取消</button>
        <button class="button primary" value="confirm">确认</button>
      </div>
    </form>
  </dialog>

  <script>
    import { wireRuntimeDeviceDeleteButtons } from "../../lib/runtime/client";

    wireRuntimeDeviceDeleteButtons({
      buttonSelector: "#device-delete-button",
      redirectTo: "/runtime/"
    });
  </script>
</BaseLayout>
