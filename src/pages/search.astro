---
import BaseLayout from "../layouts/BaseLayout.astro";
import { isOperatorMode, parseSiteMode } from "../lib/site-mode";

const siteMode = parseSiteMode(import.meta.env.PUBLIC_SITE_MODE);
---

<BaseLayout title="Search" section="search">
  <p class="eyebrow">Local index</p>
  <h1 class="page-title">
    {isOperatorMode(siteMode) ? "搜索博客和当前构建可见的 AI 资产。" : "搜索博客和公开 AI 资产说明。"}
  </h1>

  <section class="section">
    <div class="search-panel">
      <label class="search-label" for="site-search">Search query</label>
      <input
        id="site-search"
        class="search-input"
        type="search"
        placeholder="输入关键词，例如 Codex、AGENTS、pre-push"
        data-search-input
        autocomplete="off"
      />
      <div class="search-status" data-search-status>正在加载索引...</div>
      <div class="search-results" data-search-results></div>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.querySelector("[data-search-input]");
  const status = document.querySelector("[data-search-status]");
  const results = document.querySelector("[data-search-results]");

  const kindLabels = {
    blog: "Blog",
    asset: "AI Asset"
  };

  let entries = [];

  function normalize(value) {
    return String(value || "").toLocaleLowerCase();
  }

  function scoreEntry(entry, query) {
    const q = normalize(query).trim();
    if (!q) return 0;
    const title = normalize(entry.title);
    const description = normalize(entry.description);
    const text = normalize(entry.text);
    let score = 0;
    if (title.includes(q)) score += 8;
    if (description.includes(q)) score += 4;
    if (text.includes(q)) score += 2;
    for (const term of q.split(/\s+/).filter(Boolean)) {
      if (title.includes(term)) score += 3;
      if (text.includes(term)) score += 1;
    }
    return score;
  }

  function render(query) {
    if (!(results instanceof HTMLElement) || !(status instanceof HTMLElement)) return;
    const q = query.trim();
    if (!q) {
      results.innerHTML = "";
      status.textContent = `已加载 ${entries.length} 条可搜索内容。`;
      return;
    }

    const matches = entries
      .map((entry) => ({ entry, score: scoreEntry(entry, q) }))
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score || a.entry.title.localeCompare(b.entry.title))
      .slice(0, 24);

    status.textContent = matches.length === 0 ? "没有找到匹配内容。" : `找到 ${matches.length} 条匹配内容。`;
    results.innerHTML = matches
      .map(({ entry }) => `
        <a class="search-result" href="${entry.href}">
          <span>${kindLabels[entry.kind] || entry.kind}</span>
          <strong>${entry.title}</strong>
          <p>${entry.description}</p>
          <small>${entry.tags.slice(0, 5).join(" / ")}</small>
        </a>
      `)
      .join("");
  }

  function syncUrl(query) {
    const url = new URL(window.location.href);
    if (query.trim()) {
      url.searchParams.set("q", query.trim());
    } else {
      url.searchParams.delete("q");
    }
    window.history.replaceState({}, "", url);
  }

  async function initSearch() {
    if (!(input instanceof HTMLInputElement) || !(status instanceof HTMLElement)) return;
    try {
      const response = await fetch("/search-index.json");
      if (!response.ok) throw new Error(`search-index ${response.status}`);
      const payload = await response.json();
      entries = Array.isArray(payload.entries) ? payload.entries : [];
      const initialQuery = new URLSearchParams(window.location.search).get("q") || "";
      input.value = initialQuery;
      render(initialQuery);
      input.addEventListener("input", () => {
        syncUrl(input.value);
        render(input.value);
      });
    } catch {
      status.textContent = "搜索索引加载失败，请重新构建站点。";
    }
  }

  initSearch();
</script>
