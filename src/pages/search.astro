---
import BaseLayout from "../layouts/BaseLayout.astro";
import { isOperatorMode, parseSiteMode } from "../lib/site-mode";

const siteMode = parseSiteMode(import.meta.env.PUBLIC_SITE_MODE);
---

<BaseLayout title="Search" section="search">
  <p class="eyebrow">Local index</p>
  <h1 class="page-title">
    {isOperatorMode(siteMode) ? "搜索博客和当前构建可见的 AI 资产。" : "搜索博客和公开 AI 资产说明。"}
  </h1>
  <p class="lead">静态索引在构建时生成，浏览器端只做本地 fuzzy search，不触发远程查询。</p>

  <section class="section">
    <div class="search-panel">
      <label class="search-label" for="site-search">Search query</label>
      <input
        id="site-search"
        class="search-input"
        type="search"
        placeholder="输入关键词，例如 Codex、AGENTS、pre-push"
        data-search-input
        autocomplete="off"
      />
      <div class="search-status" data-search-status>正在加载索引...</div>
      <div class="search-results" data-search-results></div>
    </div>
  </section>
</BaseLayout>

<script>
  import { rankSearchEntries } from "../lib/search/query";
  import type { SearchEntry } from "../lib/search-index";

  const input = document.querySelector("[data-search-input]");
  const status = document.querySelector("[data-search-status]");
  const results = document.querySelector("[data-search-results]");

  const kindLabels: Record<string, string> = {
    blog: "Blog",
    asset: "AI Asset"
  };

  let entries: SearchEntry[] = [];

  function textElement(tagName: "span" | "strong" | "p" | "small", text: string) {
    const element = document.createElement(tagName);
    element.textContent = text;
    return element;
  }

  function resultElement(entry: SearchEntry): HTMLAnchorElement {
    const link = document.createElement("a");
    link.className = "search-result";
    link.href = entry.href;
    link.append(
      textElement("span", kindLabels[entry.kind] || entry.kind),
      textElement("strong", entry.title),
      textElement("p", entry.description),
      textElement("small", entry.tags.slice(0, 5).join(" / "))
    );
    return link;
  }

  function render(query) {
    if (!(results instanceof HTMLElement) || !(status instanceof HTMLElement)) return;
    const q = query.trim();
    if (!q) {
      results.replaceChildren();
      status.textContent = `已加载 ${entries.length} 条可搜索内容。`;
      return;
    }

    const matches = rankSearchEntries(q, entries);

    status.textContent = matches.length === 0 ? "没有找到匹配内容。" : `找到 ${matches.length} 条匹配内容。`;
    results.replaceChildren(...matches.map(resultElement));
  }

  function syncUrl(query) {
    const url = new URL(window.location.href);
    if (query.trim()) {
      url.searchParams.set("q", query.trim());
    } else {
      url.searchParams.delete("q");
    }
    window.history.replaceState({}, "", url);
  }

  async function initSearch() {
    if (!(input instanceof HTMLInputElement) || !(status instanceof HTMLElement)) return;
    try {
      const response = await fetch("/search-index.json");
      if (!response.ok) throw new Error(`search-index ${response.status}`);
      const payload = await response.json();
      entries = Array.isArray(payload.entries) ? payload.entries : [];
      const initialQuery = new URLSearchParams(window.location.search).get("q") || "";
      input.value = initialQuery;
      render(initialQuery);
      input.addEventListener("input", () => {
        syncUrl(input.value);
        render(input.value);
      });
    } catch {
      status.textContent = "搜索索引加载失败，请重新构建站点。";
    }
  }

  initSearch();
</script>
