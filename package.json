{
  "name": "ai-workflow-home",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:registry && npm run build:web",
    "build:web": "astro build",
    "build:operator": "node scripts/build-site.mjs --mode operator --outDir dist-operator",
    "operator:serve": "tsx scripts/operator-server.ts",
    "preview": "astro preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-assets.ts",
    "import:legacy": "tsx scripts/import-legacy-blog.ts",
    "runtime:baseline": "tsx scripts/runtime-assets.ts baseline",
    "runtime:inspect": "tsx scripts/runtime-assets.ts inspect",
    "runtime:device:add": "tsx scripts/runtime-assets.ts device:add",
    "runtime:scan": "tsx scripts/runtime-assets.ts scan",
    "runtime:diff": "tsx scripts/runtime-assets.ts diff",
    "runtime:sync": "tsx scripts/runtime-assets.ts sync",
    "build:registry": "tsx scripts/build-registry.ts",
    "check:registry": "tsx scripts/build-registry.ts --check",
    "check:operator-artifact": "tsx scripts/check-artifact.ts --mode operator --dir dist-operator",
    "check:artifacts": "npm run build:operator && npm run check:operator-artifact",
    "check:readonly": "npm run typecheck && npm run test && npm run validate && npm run check:registry",
    "check": "npm run check:readonly && npm run build && npm run check:artifacts"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "astro": "^6.4.8",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
